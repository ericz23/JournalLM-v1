# --- OS & editors ---
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
*~

# --- Secrets & local config (root .env is loaded by backend) ---
.env
.env.*
!.env.example

# --- Python (backend) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# --- Node / Next.js (frontend; frontend/.gitignore also applies) ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.next/
out/
build/
.vercel
*.tsbuildinfo
next-env.d.ts

# --- Local data (SQLite + WAL/SHM; do not commit personal DBs) ---
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# --- Logs & debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
